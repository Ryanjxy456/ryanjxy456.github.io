---
import BlogPage from "../layouts/BlogPage.astro";
import ToolCategory from "../components/tools/ToolCategory.astro";
import { toolCategories } from "../data/tools";
---

<BlogPage title="工具" description="我常用的工具推荐">
  <h1 class="text-4xl font-bold mb-4 text-left dark:text-white">工具分享</h1>
  <p class="text-gray-600 dark:text-gray-400 mb-8 text-lg">
    这里是一些便利或有趣的工具，希望对你有帮助。
  </p>

  {toolCategories.map((category) => (
    <ToolCategory key={category.id} category={category} />
  ))}
</BlogPage>