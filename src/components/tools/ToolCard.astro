---
const { name, description, url, icon, mirrors } = Astro.props;
---
<div class="relative group flex items-start gap-4 p-4 rounded-xl border border-gray-300 dark:border-gray-800 bg-white/50 dark:bg-zinc-900/50 transition-all duration-300 hover:border-gray-300 dark:hover:border-gray-700 hover:shadow-sm hover:bg-white dark:hover:bg-zinc-900 w-full">

  {/* 1. 图标区域 (视觉层，不抢点击) */}
  <div class="w-14 h-14 flex-shrink-0 bg-gray-50 dark:bg-gray-800/80 rounded-xl flex items-center justify-center p-2 hover:opacity-80 transition-opacity relative z-0">
    <img src={icon} alt={name} class="w-full h-full object-contain" />
  </div>

  {/* 2. 右侧内容区 */}
  <div class="flex-1 min-w-0">
    {/* 标题与全卡片点击热区 */}
    <h3 class="font-bold text-gray-900 dark:text-gray-100 text-base truncate m-0 leading-tight group-hover:text-blue-500 transition-colors">
      <a href={url} target="_blank" class="focus:outline-none no-underline" aria-label={`访问 ${name}`}>
        {/* 核心魔法：这个空 span 会自动撑满整个最外层卡片，形成透明点击层 */}
        <span class="absolute inset-0 z-10" aria-hidden="true"></span>
        {name}
      </a>
    </h3>

    {/* 描述文本 (鼠标事件穿透，防选中) */}
    <p class="text-sm text-gray-500 dark:text-gray-400 truncate mt-1 m-0 leading-tight select-none pointer-events-none relative z-0">
      {description}
    </p>

    {/* 3. 独立节点按钮 (高层级，拦截点击) */}
    {mirrors && mirrors.length > 0 && (
      <div class="relative z-20 flex flex-wrap gap-2 mt-3 pointer-events-none">
        {mirrors.map((mirror: any) => (
          <a
            href={mirror.url}
            target="_blank"
            class="relative z-20 pointer-events-auto flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium text-gray-600 dark:text-gray-300 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-full hover:bg-blue-50 dark:hover:bg-blue-900/30 hover:border-blue-400 dark:hover:border-blue-500 hover:text-blue-600 dark:hover:text-blue-400 transition-all duration-200 no-underline shadow-sm group/mirror"
          >
            {mirror.icon && (
              <img src={mirror.icon} alt={mirror.name} class="w-3.5 h-3.5 opacity-70 group-hover/mirror:opacity-100 transition-opacity" />
            )}
            {mirror.name}
          </a>
        ))}
      </div>
    )}
  </div>
</div>